<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>お問い合わせ一覧</title>
  </head>
  <body>
    <h1>お問い合わせ一覧</h1>
    <table>
      <thead>
        <tr>
          <th>名前</th>
          <th>件名</th>
          <th>ステータス</th>
          <th>受付日時</th>
        </tr>
      </thead>
      <tbody>
        <% contacts.forEach(function (contact) { %>
          <tr>
            <td><a href="/admin/<%= contact.id %>"><%= contact.name %></a></td>
            <td><%= contact.subject %></td>
            <td><%= contact.statusLabel %></td>
            <td><%= contact.createdAtJst %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </body>
</html>
