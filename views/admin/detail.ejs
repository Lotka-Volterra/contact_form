<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>お問い合わせ詳細</title>
  </head>
  <body>
    <h1>お問い合わせ詳細</h1>
    <% if (typeof error !== 'undefined' && error) { %>
      <ul class="errors">
        <li><%= error %></li>
      </ul>
    <% } %>
    <dl>
      <dt>名前</dt>
      <dd><%= contact.name %></dd>
      <dt>メールアドレス</dt>
      <dd><%= contact.email %></dd>
      <dt>件名</dt>
      <dd><%= contact.subject %></dd>
      <dt>本文</dt>
      <dd><%= contact.body %></dd>
      <dt>受付日時</dt>
      <dd><%= contact.createdAtJst %></dd>
    </dl>

    <form method="post" action="/admin/<%= contact.id %>/status">
      <label>
        ステータス
        <select name="status">
          <% statuses.forEach(function (status) { %>
            <option value="<%= status %>" <% if (status === contact.status) { %>selected<% } %>>
              <%= labelFor(status) %>
            </option>
          <% }); %>
        </select>
      </label>
      <button type="submit">更新する</button>
    </form>

    <a href="/admin">一覧に戻る</a>
  </body>
</html>
