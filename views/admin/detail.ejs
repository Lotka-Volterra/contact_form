<!doctype html>
<html lang="ja">
  <head>
    <%- include('../partials/head', { title: 'お問い合わせ詳細' }) %>
  </head>
  <body>
    <div class="container">
      <div class="card">
        <h1>お問い合わせ詳細</h1>
        <% if (typeof error !== 'undefined' && error) { %>
          <ul class="errors">
            <li><%= error %></li>
          </ul>
        <% } %>
        <dl class="summary-list">
          <dt>名前</dt>
          <dd><%= contact.name %></dd>
          <dt>メールアドレス</dt>
          <dd><%= contact.email %></dd>
          <dt>件名</dt>
          <dd><%= contact.subject %></dd>
          <dt>本文</dt>
          <dd><%= contact.body %></dd>
          <dt>受付日時</dt>
          <dd><%= contact.createdAtJst %></dd>
        </dl>

        <form method="post" action="/admin/<%= contact.id %>/status">
          <div class="field">
            <label class="field-label">
              ステータス
              <select name="status" class="select">
                <% statuses.forEach(function (status) { %>
                  <option value="<%= status %>" <% if (status === contact.status) { %>selected<% } %>>
                    <%= labelFor(status) %>
                  </option>
                <% }); %>
              </select>
            </label>
          </div>
          <button type="submit" class="btn btn-primary">更新する</button>
        </form>

        <a href="/admin" class="back-link">一覧に戻る</a>
      </div>
    </div>
  </body>
</html>
