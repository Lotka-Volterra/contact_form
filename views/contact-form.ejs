<!doctype html>
<html lang="ja">
  <head>
    <%- include('partials/head', { title: 'お問い合わせフォーム' }) %>
  </head>
  <body>
    <div class="container">
      <div class="card">
        <h1>お問い合わせフォーム</h1>
        <% if (errors && errors.length > 0) { %>
          <ul class="errors">
            <% errors.forEach(function (error) { %>
              <li><%= error %></li>
            <% }); %>
          </ul>
        <% } %>
        <form method="post" action="/confirm">
          <div class="field">
            <label class="field-label">
              名前
              <input type="text" class="input" name="name" value="<%= values.name %>" required />
            </label>
          </div>
          <div class="field">
            <label class="field-label">
              メールアドレス
              <input type="email" class="input" name="email" value="<%= values.email %>" required />
            </label>
          </div>
          <div class="field">
            <label class="field-label">
              件名
              <input type="text" class="input" name="subject" value="<%= values.subject %>" required />
            </label>
          </div>
          <div class="field">
            <label class="field-label">
              本文
              <textarea name="body" class="textarea" rows="10" required><%= values.body %></textarea>
            </label>
          </div>
          <button type="submit" class="btn btn-primary">確認画面へ</button>
        </form>
      </div>
    </div>
  </body>
</html>
