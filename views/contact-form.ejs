<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>お問い合わせフォーム</title>
  </head>
  <body>
    <h1>お問い合わせフォーム</h1>
    <% if (errors && errors.length > 0) { %>
      <ul class="errors">
        <% errors.forEach(function (error) { %>
          <li><%= error %></li>
        <% }); %>
      </ul>
    <% } %>
    <form method="post" action="/confirm">
      <label>
        名前
        <input type="text" name="name" value="<%= values.name %>" required />
      </label>
      <label>
        メールアドレス
        <input type="email" name="email" value="<%= values.email %>" required />
      </label>
      <label>
        件名
        <input type="text" name="subject" value="<%= values.subject %>" required />
      </label>
      <label>
        本文
        <textarea name="body" required><%= values.body %></textarea>
      </label>
      <button type="submit">確認画面へ</button>
    </form>
  </body>
</html>
